# Copy to `.env` and adjust. Only EXPO_PUBLIC_* vars are exposed to the app.
# NEVER put secrets here — anything EXPO_PUBLIC_* is bundled into the client.

# Base URL of the existing NestJS backend.
EXPO_PUBLIC_API_URL=https://api.dairyplatform.example.com

# When "true", the app runs entirely on in-memory mocks (no backend needed).
# Use this to develop/screenshot the UI before backend endpoints are confirmed.
EXPO_PUBLIC_USE_MOCKS=true

# Sentry DSN (optional in dev). Leave blank to disable.
EXPO_PUBLIC_SENTRY_DSN=
